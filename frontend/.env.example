# EmailJS Configuration
# Copiez ce fichier en .env et remplacez les valeurs par vos vraies clés EmailJS

# Service ID - Obtenu depuis EmailJS Dashboard > Email Services
VITE_EMAILJS_SERVICE_ID=service_abc123

# Template ID - Obtenu depuis EmailJS Dashboard > Email Templates  
VITE_EMAILJS_TEMPLATE_ID=template_xyz789

# Public Key - Obtenu depuis EmailJS Dashboard > Account > General
VITE_EMAILJS_PUBLIC_KEY=votre_public_key_ici

# Instructions complètes dans EMAILJS_CONFIG_GUIDE.md
